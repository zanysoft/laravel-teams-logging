{
	"name": "zanysoft/laravel-teams-logging",
	"description": "Laravel handler to sending messages to Microsoft Teams using the Incoming Webhook connector",
    "keywords": [
      "Laravel",
      "Laravel Logging",
      "Exception Monitor",
      "Teams",
      "Microsoft",
      "Microsoft Teams",
      "Logging",
      "zanysoft"
    ],
	"license": "MIT",
	"authors": [
		{
			"name": "ZanySoft",
			"email": "zanysoft.us@gmail.com"
		}
	],
	"require": {
		"php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
		"monolog/monolog": "^3.0"
	},
	"require-dev": {
		"ext-curl": "*"
	},
	"autoload": {
		"psr-4": {
			"ZanySoft\\LaravelTeamsLogging\\": "src/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"ZanySoft\\LaravelTeamsLogging\\LoggerServiceProvider"
			]
		}
	}
}
